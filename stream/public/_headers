# === LSFPlus Cache Rules ===
# These headers are read by Cloudflare Pages and static-web-server.

# index.html — NEVER cache. Cloudflare must always revalidate.
# This is what the browser fetches first; if stale, everything breaks.
/index.html
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

# Service Worker — NEVER cache. Must always be fresh so updates propagate.
/sw.js
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

# Workbox runtime — NEVER cache (same reason as sw.js)
/workbox-*.js
  Cache-Control: no-store, no-cache, must-revalidate

# Hashed assets (JS/CSS/fonts) — Cache FOREVER. Vite content-hashes these,
# so a new build = new filename = no stale cache issue.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Manifest — short cache so icon/name changes are picked up quickly
/manifest.webmanifest
  Cache-Control: public, max-age=86400

# Images in public folder — moderate cache
/images/*
  Cache-Control: public, max-age=604800
